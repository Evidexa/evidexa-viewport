# Extension build artifacts — never commit these
# .pem — private signing key, store in a password manager / secrets vault
*.pem
# .crx — packed extension binary, regenerate from source with the .pem
*.crx
# .zip — Web Store upload ZIPs, generated by scripts/pack-webstore.sh
*.zip

# Dependencies
node_modules/
tests/node_modules/

# macOS
.DS_Store
**/.DS_Store

# Scratch / temp assets
~Temp/

# Editor
.vscode/
*.swp
*.swo
